# =============================================
# ARATI PRECISION INDUSTRIES - Backend Config
# Copy this file to .env and fill in values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB (optional — falls back to JSON file if not set)
MONGODB_URI=mongodb://localhost:27017/arati_precision

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (optional — skip email if not set)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Admin notification email
ADMIN_EMAIL=admin@aratiprecision.com

# Admin panel secret key (change this to something strong!)
ADMIN_SECRET=your_admin_secret_key_change_this
